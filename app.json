{
  "expo": {
    "name": "Futly Go",
    "slug": "futly_go",
    "version": "1.0.0",
    "scheme": "futlygo",
    "orientation": "portrait",
    "icon": "./assets/icons/Icon-512.png",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/icons/Icon-512.png",
      "resizeMode": "contain",
      "backgroundColor": "#05070B"
    },
    "ios": {
      "bundleIdentifier": "com.fabricio.futlygo",
      "usesAppleSignIn": true,
      "entitlements": {
        "aps-environment": "development"
      },
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSCameraUsageDescription": "Precisamos de acesso à câmera para tirar fotos e gravar vídeos no chat.",
        "NSPhotoLibraryUsageDescription": "Precisamos de acesso à galeria para enviar fotos e vídeos no chat.",
        "NSPhotoLibraryAddUsageDescription": "Precisamos de acesso para salvar mídias compartilhadas no chat.",
        "NSMicrophoneUsageDescription": "Precisamos de acesso ao microfone para gravar áudios no chat.",
        "UIBackgroundModes": ["audio"]
      },
      "supportsTablet": true
    },
    "android": {
      "package": "com.fabricio.futlygo",
      "permissions": [
        "CAMERA",
        "RECORD_AUDIO",
        "READ_MEDIA_IMAGES",
        "READ_MEDIA_VIDEO",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE",
        "android.permission.MODIFY_AUDIO_SETTINGS"
      ],
      "adaptiveIcon": {
        "foregroundImage": "./assets/icons/Icon-maskable-512.png",
        "backgroundColor": "#05070B"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "name": "Futly Go",
      "shortName": "Futly Go",
      "themeColor": "#05060A",
      "backgroundColor": "#05060A",
      "meta": {
        "apple-mobile-web-app-capable": "yes",
        "apple-mobile-web-app-status-bar-style": "black-translucent",
        "apple-mobile-web-app-title": "Futly Go",
        "application-name": "Futly Go"
      },
      "favicon": "./public/favicon.png"
    },
    "plugins": [
      "expo-router",
      "@react-native-community/datetimepicker",
      "expo-font",
      "expo-notifications",
      "expo-web-browser",
      "expo-audio",
      "expo-video"
    ],
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "enabled": true,
      "url": "https://u.expo.dev/ea29ea84-2421-4733-ba4a-2146c6bcb0e8"
    },
    "extra": {
      "eas": {
        "projectId": "ea29ea84-2421-4733-ba4a-2146c6bcb0e8"
      },
      "router": {}
    },
    "owner": "fabricio_rv"
  }
}
