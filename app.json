{
  "expo": {
    "name": "Futly Go",
    "slug": "futly_go",
    "version": "1.0.0",
    "scheme": "futlygo",
    "orientation": "portrait",
    "icon": "./assets/icons/Icon-512.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": false,
    "splash": {
      "image": "./assets/icons/Icon-512.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "bundleIdentifier": "com.fabricio.futlygo",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      },
      "supportsTablet": true
    },
    "android": {
      "package": "com.fabricio.futlygo",
      "adaptiveIcon": {
        "foregroundImage": "./assets/icons/Icon-maskable-512.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "name": "Futly Go",
      "shortName": "Futly Go",
      "themeColor": "#05060A",
      "backgroundColor": "#05060A",
      "meta": {
        "apple-mobile-web-app-capable": "yes",
        "apple-mobile-web-app-status-bar-style": "black-translucent",
        "apple-mobile-web-app-title": "Futly Go",
        "application-name": "Futly Go"
      },
      "favicon": "./public/favicon.png"
    },
    "plugins": [
      "expo-router",
      "@react-native-community/datetimepicker",
      "expo-font",
      "expo-web-browser"
    ],
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "2395764d-a3b8-4bff-8311-91f19670dffd"
      }
    },
    "owner": "suporte04atsd",
    "updates": {
      "url": "https://u.expo.dev/2395764d-a3b8-4bff-8311-91f19670dffd"
    }
  }
}
